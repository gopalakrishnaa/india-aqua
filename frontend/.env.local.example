# Copy to .env.local and fill in real values. NEVER commit .env.local.
# Server-only. Never exposed to the browser (no NEXT_PUBLIC_ prefix).

BACKEND_API_URL=http://localhost:8000

# Create a client and key with: uv run india-aqua seed  (or via the CLI's create_client helper)
BACKEND_API_KEY=your-backend-api-key-here

# Public Supabase client config (exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
