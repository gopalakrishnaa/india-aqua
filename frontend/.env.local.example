# Copy to .env.local and fill in real values. NEVER commit .env.local.
# Server-only — never exposed to the browser (no NEXT_PUBLIC_ prefix).

BACKEND_API_URL=http://localhost:8000

# Create a client and key with: uv run ganga-aqua seed  (or via the CLI's create_client helper)
BACKEND_API_KEY=your-backend-api-key-here
