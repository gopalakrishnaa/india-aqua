# ─────────────────────────────────────────────────────────────
# india-aqua: example environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres) ────────────────────────────
# Supabase → Project Settings → Database → "Connection string" (URI format).
# Use the DIRECT (session pooler) connection for Alembic migrations, and the
# transaction pooler (port 6543) for the app if you prefer connection pooling.
# Example:
#   postgresql://postgres.[project]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/india_aqua

# Optional separate URL used only for running migrations (defaults to DATABASE_URL).
# DATABASE_MIGRATION_URL=

# ── LLM provider (hallucination validator) ─────────────────
# NVIDIA NIM (OpenAI-compatible). Get a key at https://build.nvidia.com
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
LLM_TEMPERATURE=0

# ── API / SaaS auth ─────────────────────────────────────────
# Secret used to sign API keys. Change to a long random string in production.
API_KEY_SECRET=change-me-to-a-long-random-secret
# Default rate limit per SaaS client window, format "<limit>/<period>". slowapi syntax.
DEFAULT_RATE_LIMIT=60/minute
# Bootstrap admin client created by `india-aqua seed` (api key is stored hashed in DB).
# Leave blank to skip creating a bootstrap client.
BOOTSTRAP_API_KEY=

# ── App ─────────────────────────────────────────────────────
APP_NAME=india-aqua
ENVIRONMENT=development
LOG_LEVEL=INFO
# CORS comma-separated origins (use * only for local dev)
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ── Scraping (Playwright) ───────────────────────────────────
# Headless browser when scraping live gov sites.
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=30000

# ── Scheduled scrape (Vercel Cron) ──────────────────────────
# Guards GET /api/v1/internal/cron/scrape, which Vercel Cron hits on the
# schedule in vercel.json to pull the live CPCB SWAN feed automatically.
# Vercel auto-sends `Authorization: Bearer $CRON_SECRET` on cron requests
# when this var is set on the project. Nothing else to wire up. Leave
# blank to disable the endpoint (returns 404).
CRON_SECRET=
